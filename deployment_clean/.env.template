# DB Analyzer AI v7 — copy to .env and fill. Never commit .env.
#
# Docker: set APP_HOST=0.0.0.0. Match APP_PORT to EXPOSE (default 8004).

# App
APP_HOST=0.0.0.0
APP_PORT=8004

# AMAIZ
AMAIZ_TENANT_ID=
AMAIZ_BASE_URL=
AMAIZ_API_KEY=
AMAIZ_GENAIAPP_RUNTIME_ID=
HTTPX_REQUEST_TIMEOUT=600
AMAIZ_CHAT_FLOW_NAME=chat
AMAIZ_FLOW_NAME=db_analysis_amaiz_pipeline
AMAIZ_CONTEXT_KEY=context_data

# Paths (relative to app root)
# PROMPTS_DIR=prompts
#REPORTS_DIR=reports
#DATA_DIR=data
#MEMORY_DIR=memory

# DB
POSTGRES_DSN=
COUCHBASE_CONNECTION_STRING=couchbase://localhost
COUCHBASE_BUCKET=
COUCHBASE_USERNAME=
COUCHBASE_PASSWORD=

# MCP
MCP_POSTGRES_DSN=
MCP_COUCHBASE_CONNECTION_STRING=
MCP_COUCHBASE_BUCKET=
MCP_COUCHBASE_USERNAME=
MCP_COUCHBASE_PASSWORD=

# Keycloak (optional)
KEYCLOAK_SERVER_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Security
API_KEY=
CORS_ALLOWED_ORIGINS=*
# Optional extra CORS origins, comma-separated (e.g. https://tracewise-ui:8443). Set per environment.
CORS_EXTRA_ORIGINS=

# Optional
SCHEMA_CACHE_TTL_SECONDS=300
MONITORING_INTERVAL_MINUTES=10
PIPELINE_STAGE_TIMEOUT=120
PIPELINE_MAX_CONCURRENCY=5
LOG_LEVEL=INFO
ENVIRONMENT=production
