# DB Analyzer AI v5 — copy to .env and fill. Never commit .env.

# App
APP_HOST=127.0.0.1
APP_PORT=8002

# AMAIZ
AMAIZ_TENANT_ID=
AMAIZ_BASE_URL=
AMAIZ_API_KEY=
AMAIZ_GENAIAPP_RUNTIME_ID=
HTTPX_REQUEST_TIMEOUT=600
AMAIZ_CHAT_FLOW_NAME=chat
AMAIZ_FLOW_NAME=db_analysis_amaiz_pipeline
AMAIZ_CONTEXT_KEY=context_data

# Paths (relative to v5)
PROMPTS_DIR=prompts
REPORTS_DIR=reports
DATA_DIR=data
MEMORY_DIR=memory

# DB
POSTGRES_DSN=
COUCHBASE_CONNECTION_STRING=couchbase://localhost
COUCHBASE_BUCKET=
COUCHBASE_USERNAME=
COUCHBASE_PASSWORD=

# MCP
MCP_POSTGRES_DSN=
MCP_COUCHBASE_CONNECTION_STRING=
MCP_COUCHBASE_BUCKET=
MCP_COUCHBASE_USERNAME=
MCP_COUCHBASE_PASSWORD=

# Keycloak (optional — leave empty for dev/API-key mode)
KEYCLOAK_SERVER_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Security
API_KEY=
CORS_ALLOWED_ORIGINS=*

# Schema cache (seconds); 0 = disabled
SCHEMA_CACHE_TTL_SECONDS=300

# Monitoring interval (minutes)
MONITORING_INTERVAL_MINUTES=10

# Pipeline
PIPELINE_STAGE_TIMEOUT=120
PIPELINE_MAX_CONCURRENCY=5

LOG_LEVEL=INFO
ENVIRONMENT=dev
